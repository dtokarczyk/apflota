# App → PostgreSQL (w docker-compose domyślnie serwis `postgres`, port wewnętrzny 5432)
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=konkurs
DATABASE_PASSWORD=konkurs
DATABASE_NAME=konkurs

# Port Postgresa na hoście (gdy masz lokalny 5432 zajęty: np. 5433)
POSTGRES_PUBLISH_PORT=5432

# Zewnętrzna baza (np. Railway) — ustaw DATABASE_HOST i pomiń / wyłącz serwis postgres w compose
# DATABASE_HOST=your-host.example.com

# Backend behind nginx in Docker: default 3000 (nginx upstream). Optional override for local runs.
# NEST_LISTEN_PORT=3000
